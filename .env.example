# RPC allowlist — the ONLY outbound hosts this service may contact.
# Verified with scripts/probe-rpc.ts on 2026-07-14.

# X Layer (chainId 196) — OKX.AI settlement chain.
# NOTE: no X Layer RPC supports eth_simulateV1 (OKX's own endpoints 403 on it), so this chain
# runs decode-only. That still catches every approval drainer. Re-probe before assuming otherwise.
SCOUT_RPC_196=https://rpc.xlayer.tech

# Ethereum mainnet (chainId 1) — supports eth_simulateV1, so full simulation runs here.
# publicnode and eth.drpc.org both verified working. cloudflare-eth does NOT support it.
SCOUT_RPC_1=https://ethereum-rpc.publicnode.com

# Pricing (USDT per call). Market context: CertiK 0.001, CA X-Ray 0.2, SentryX 0.5.
# We are compute-heavy but must stay volume-competitive for Revenue Rocket.
SCOUT_PRICE_USDT=0.01

# OKX x402 / Payment SDK — receiving address for pay-per-call settlement.
# NEVER a private key. This service does not sign.
SCOUT_PAYTO_ADDRESS=0x0000000000000000000000000000000000000000

# OKX x402 facilitator credentials — OPTIONAL. Leave blank to run the gate UNVERIFIED
# (pre-settlement behaviour). Set ALL THREE to verify + settle real payments and collect USDT.
# Create these in your OKX account (API management). Secrets — never commit real values.
SCOUT_OKX_API_KEY=
SCOUT_OKX_API_SECRET=
SCOUT_OKX_API_PASSPHRASE=
# Facilitator host. Fixed by env (not user-supplied). Override only for testing.
SCOUT_X402_FACILITATOR_URL=https://web3.okx.com

PORT=8787
LOG_LEVEL=info
