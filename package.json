{
  "name": "scout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Simulates a pending transaction and returns a plain-English safety verdict. Pay-per-call MCP server for OKX.AI.",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.1",
    "fastify": "5.3.2",
    "viem": "2.31.0",
    "zod": "3.25.42"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.1.4"
  }
}
